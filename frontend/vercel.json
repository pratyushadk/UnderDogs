{
  "rewrites": [
    { "source": "/auth/(.*)",   "destination": "https://worksafe-backend.onrender.com/auth/$1" },
    { "source": "/api/(.*)",    "destination": "https://worksafe-backend.onrender.com/api/$1" },
    { "source": "/admin/(.*)",  "destination": "https://worksafe-backend.onrender.com/admin/$1" },
    { "source": "/health",      "destination": "https://worksafe-backend.onrender.com/health" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
