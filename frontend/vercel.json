{
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://worksafe-backend1.onrender.com/auth/:path*" },
    { "source": "/api/:path*",  "destination": "https://worksafe-backend1.onrender.com/api/:path*" },
    { "source": "/admin/:path*","destination": "https://worksafe-backend1.onrender.com/admin/:path*" },
    { "source": "/health",      "destination": "https://worksafe-backend1.onrender.com/health" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
