{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'skip root install'",
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "https://worksafe-backend1.onrender.com/auth/$1",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "headers": { "Access-Control-Allow-Origin": "*" }
    },
    {
      "src": "/api/(.*)",
      "dest": "https://worksafe-backend1.onrender.com/api/$1",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "headers": { "Access-Control-Allow-Origin": "*" }
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "https://worksafe-backend1.onrender.com/api/admin/$1",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "headers": { "Access-Control-Allow-Origin": "*" }
    },
    {
      "src": "/health",
      "dest": "https://worksafe-backend1.onrender.com/health",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

