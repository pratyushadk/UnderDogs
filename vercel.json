{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/auth/:path*",  "destination": "https://worksafe-backend-983k.onrender.com/auth/:path*" },
    { "source": "/api/:path*",   "destination": "https://worksafe-backend-983k.onrender.com/api/:path*" },
    { "source": "/admin/:path*", "destination": "https://worksafe-backend-983k.onrender.com/admin/:path*" },
    { "source": "/health",       "destination": "https://worksafe-backend-983k.onrender.com/health" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ]
}
